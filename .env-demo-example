# Environment for the demo-mode deployment (docker-compose.demo.yml).

DEMO_MODE=1
BASEDOMAIN=autoleak.org                       # main public domain
CROSSORIGINDOMAIN=crossorigin.autoleak.org    # cross-origin domain (same backend)
TEST_CONFIG=testconfigs/config.json           # config the app loads at startup

MONGO_PASSWORD=12345

# Traefik integration 
TRAEFIK_NETWORK=traefik       # name of the existing external Traefik docker network
TRAEFIK_ENTRYPOINT=websecure  # Traefik HTTPS entrypoint name
CERT_RESOLVER=letsencrypt     # Traefik ACME certresolver name

# Not used by the demo (no nginx/basic-auth), kept for parity with .env-example:
# FRONTEND_USERNAME=nds
# FRONTEND_PASSWORD=changeme
